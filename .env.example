# ==========================================
# EXP CRICKET (XPERT CRICKET) ENVIRONMENT EXAMPLE
# Copy this file to .env.local and populate with your credentials
# ==========================================

NEXT_PUBLIC_APP_NAME=EXP Cricket
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Administrative Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Supabase Future Integration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI Provider Configuration (gemini | openai | grok)
DEFAULT_AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
XAI_API_KEY=your_xai_api_key
